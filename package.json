{
  "name": "obix-todoapp",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "OBIX TodoApp - Standalone Team Collaboration with #NoGhosting Protocol & SQLite Persistence",
  "author": "OBINexus <okpalan@protonmail.com>",
  "license": "MIT",
  "main": "dist/core/index.js",
  "types": "dist/core/index.d.ts",
  "bin": {
    "obix-todoapp": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.backend.json && npm run postbuild",
    "postbuild": "node scripts/fix-esm.cjs",
    "build:backend": "tsc -p tsconfig.backend.json && npm run postbuild",
    "build:ui": "vite build",
    "build:full": "tsc -p tsconfig.backend.json && npm run build:ui && npm run postbuild",
    "dev": "tsc -p tsconfig.backend.json --watch",
    "dev:ui": "vite",
    "start": "node dist/server/app.js",
    "cli": "node dist/cli/index.js",
    "test": "vitest run",
    "watch": "tsc -p tsconfig.backend.json --watch",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@obinexusltd/obix-core": "^0.1.0",
    "@obinexusltd/obix-state": "^0.1.0",
    "better-sqlite3": "^9.2.2",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "inquirer": "^8.2.5",
    "table": "^6.8.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.0",
    "chai": "^4.3.0",
    "concurrently": "^8.2.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
