{
  "name": "obix-todoapp",
  "version": "0.1.0",
  "private": true,
  "description": "OBIX TodoApp - Standalone Team Collaboration with #NoGhosting Protocol & SQLite Persistence",
  "author": "OBINexus <okpalan@protonmail.com>",
  "license": "MIT",
  "main": "dist/core/index.js",
  "types": "dist/core/index.d.ts",
  "bin": {
    "obix-todoapp": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && npm run build:ui",
    "build:ui": "vite build",
    "dev": "concurrently \"npm run dev:tsc\" \"npm run dev:ui\"",
    "dev:tsc": "tsc --watch",
    "dev:ui": "vite",
    "start": "node dist/server/app.js",
    "cli": "node dist/cli/index.js",
    "test": "vitest run",
    "watch": "tsc --watch",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@obinexusltd/obix-core": "^0.1.0",
    "@obinexusltd/obix-state": "^0.1.0",
    "express": "^4.18.2",
    "better-sqlite3": "^9.2.2",
    "commander": "^11.1.0",
    "chalk": "^5.3.0",
    "inquirer": "^8.2.5",
    "table": "^6.8.1",
    "cors": "^2.8.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.21",
    "@types/better-sqlite3": "^7.6.8",
    "@types/uuid": "^9.0.7",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0",
    "chai": "^4.3.0",
    "vite": "^5.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
